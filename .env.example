# ═══════════════════════════════════════════
# JARVIS Trading Agent System - Configuration
# ═══════════════════════════════════════════

# NVIDIA NIM API (kostenlos: https://build.nvidia.com/settings/api-keys)
NVIDIA_API_KEY=nvapi-DEIN_KEY_HIER

# Default LLM Model (kostenlos auf NIM)
JARVIS_MODEL=moonshotai/kimi-k2.5
# Alternativen:
# JARVIS_MODEL=z-ai/glm-5
# JARVIS_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# JARVIS_MODEL=deepseek-ai/deepseek-r1

# Vision Model für Chart-Analyse
JARVIS_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct

# Exchange (für Phase 1: nur Daten holen, kein Trading)
EXCHANGE=bybit
# Optional: API Keys für Live-Trading (Phase 4)
# EXCHANGE_API_KEY=
# EXCHANGE_SECRET=

# Trading Pairs
WATCHLIST=BTC/USDT,ETH/USDT

# Risk Management
MAX_RISK_PER_TRADE=0.02
ACCOUNT_BALANCE=1000

# Telegram Bot (optional, Phase 4)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
